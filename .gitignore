# Ignore PHP specific files
vendor/

# Ignore Composer lock file
composer.lock

# Ignore IDE and editor specific files
.idea/
*.iml

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore log files and databases
*.log

# Ignore PHPUnit test results
phpunit.xml.dist
junit.xml
phpunit.xml.*
.phpunit.result.cache

# Ignore coverage reports
coverage/

# Never allow OpenAPI spec files to be committed to this repo.
# Specs live in opportify/documentation — they are read-only inputs.
openapi-*.yml
openapi-*.yaml
*.openapi.yml
*.openapi.yaml